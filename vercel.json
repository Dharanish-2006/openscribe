{
  "buildCommand": "cd frontend/open-scribe && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/open-scribe/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://openscribe.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://openscribe.onrender.com/ws/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}