{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://openscribe.onrender.com/api/:path*"
    },
    {
      "source": "/ws/:path*",
      "destination": "https://openscribe.onrender.com/ws/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
